# Protege arquivos sensíveis do backend contra acesso direto por URL. (Apache)
# Não bloqueia os .php do endpoint/dashboard, que precisam ser servidos.
<IfModule mod_authz_core.c>
  <FilesMatch "\.(sqlite|sqlite-wal|sqlite-shm|db)$">
    Require all denied
  </FilesMatch>
  <Files "config.php">
    Require all denied
  </Files>
</IfModule>
<IfModule !mod_authz_core.c>
  <FilesMatch "\.(sqlite|sqlite-wal|sqlite-shm|db)$">
    Order allow,deny
    Deny from all
  </FilesMatch>
  <Files "config.php">
    Order allow,deny
    Deny from all
  </Files>
</IfModule>

# Nginx (equivalente, para quem usa Nginx em vez de Apache):
#   location ~* \.(sqlite|sqlite-wal|sqlite-shm|db)$ { deny all; }
#   location = /server/config.php { deny all; }
